{
  "name": "kintai-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev:app": "npm run dev --workspace=apps/kintai-app",
    "dev:admin": "npm run dev --workspace=apps/kintai-admin",
    "dev": "npm run dev:app & npm run dev:admin",
    "build:app": "npm run build --workspace=apps/kintai-app",
    "build:admin": "npm run build --workspace=apps/kintai-admin",
    "build": "npm run build:app && npm run build:admin",
    "db:migrate": "npm run db:migrate --workspace=packages/shared",
    "db:seed": "npm run db:seed --workspace=packages/shared",
    "db:studio": "npm run db:studio --workspace=packages/shared",
    "test": "vitest run",
    "test:integration": "vitest run --project kintai-app --project kintai-admin",
    "test:watch": "vitest",
    "test:unit": "vitest run --project shared",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:ui": "cd e2e && npx playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "docx": "^9.6.1"
  }
}
